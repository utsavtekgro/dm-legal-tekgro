{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "760px",
			"wideSize": "1120px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"custom": true,
			"customDuotone": false,
			"palette": [
				{ "slug": "ink", "color": "#1a2332", "name": "Ink" },
				{ "slug": "ink-soft", "color": "#39465a", "name": "Ink Soft" },
				{ "slug": "paper", "color": "#fbfaf7", "name": "Paper" },
				{ "slug": "paper-shade", "color": "#f1eee7", "name": "Paper Shade" },
				{ "slug": "brass", "color": "#8b6f47", "name": "Brass" },
				{ "slug": "brass-bright", "color": "#a9884f", "name": "Brass Bright" },
				{ "slug": "line", "color": "#e0dbd1", "name": "Hairline" },
				{ "slug": "white", "color": "#ffffff", "name": "White" }
			]
		},
		"typography": {
			"fluid": true,
			"customFontSize": true,
			"lineHeightSettings": true,
			"dropCap": false,
			"fontFamilies": [
				{
					"slug": "display",
					"name": "Display Serif",
					"fontFamily": "\"Iowan Old Style\", \"Palatino Linotype\", Palatino, \"Book Antiqua\", Georgia, \"Times New Roman\", serif"
				},
				{
					"slug": "body",
					"name": "Body Sans",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif"
				},
				{
					"slug": "mono",
					"name": "Mono",
					"fontFamily": "ui-monospace, SFMono-Regular, \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", monospace"
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.875rem", "name": "Small", "fluid": false },
				{ "slug": "medium", "size": "1.0625rem", "name": "Medium", "fluid": false },
				{ "slug": "large", "size": "clamp(1.25rem, 1.1rem + 0.6vw, 1.5rem)", "name": "Large" },
				{ "slug": "x-large", "size": "clamp(1.75rem, 1.4rem + 1.4vw, 2.5rem)", "name": "Extra Large" },
				{ "slug": "xx-large", "size": "clamp(2.25rem, 1.6rem + 2.6vw, 3.75rem)", "name": "Display" }
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"customSpacingSize": true,
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{ "slug": "20", "size": "0.75rem", "name": "1" },
				{ "slug": "30", "size": "1.25rem", "name": "2" },
				{ "slug": "40", "size": "2rem", "name": "3" },
				{ "slug": "50", "size": "3.25rem", "name": "4" },
				{ "slug": "60", "size": "5rem", "name": "5" },
				{ "slug": "70", "size": "8rem", "name": "6" }
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--paper)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.65"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"left": "clamp(1rem, 5vw, 2rem)",
				"right": "clamp(1rem, 5vw, 2rem)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "1.15",
					"letterSpacing": "-0.01em"
				},
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--brass)" },
				":hover": {
					"typography": { "textDecoration": "underline" }
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--ink)",
					"text": "var(--wp--preset--color--paper)"
				},
				"border": { "radius": "2px" },
				"spacing": {
					"padding": {
						"top": "0.85rem",
						"bottom": "0.85rem",
						"left": "1.75rem",
						"right": "1.75rem"
					}
				},
				":hover": {
					"color": { "background": "var(--wp--preset--color--brass)" }
				}
			}
		}
	},
	"customTemplates": [],
	"templateParts": []
}
